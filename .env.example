# AI Video Generator Environment Variables
# Copy this file to .env and add your API keys

# ElevenLabs API Key (Optional - for premium voice generation)
# Get your key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API Key (Optional - for future features)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Bing Image Creator Cookie (Optional - for automated image generation)
# Instructions: https://github.com/acheong08/BingImageCreator
BING_COOKIE=your_bing_cookie_here
